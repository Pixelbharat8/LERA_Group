# Copy to .env.local and adjust if needed
# All frontend requests go through Next.js rewrites to backend services
NEXT_PUBLIC_API_BASE_URL=

# Used by next.config.js rewrites (correct port mapping)
# Identity=8081, Academy=8082, Payment=8083, Payroll=8084,
# Attendance=8085, Connect=8086, AI Gateway=8087, Rule Engine=8088, Social Media=8089
IDENTITY_SERVICE_URL=http://localhost:8081
ACADEMY_SERVICE_URL=http://localhost:8082
PAYMENT_SERVICE_URL=http://localhost:8083
PAYROLL_SERVICE_URL=http://localhost:8084
ATTENDANCE_SERVICE_URL=http://localhost:8085
CONNECT_SERVICE_URL=http://localhost:8086
AI_GATEWAY_URL=http://localhost:8087
RULE_ENGINE_URL=http://localhost:8088
SOCIAL_MEDIA_SERVICE_URL=http://localhost:8089

# Direct service URLs for frontend (used in client-side fetch)
NEXT_PUBLIC_IDENTITY_SERVICE_URL=http://localhost:8081
NEXT_PUBLIC_ACADEMY_SERVICE_URL=http://localhost:8082
NEXT_PUBLIC_PAYMENT_SERVICE_URL=http://localhost:8083
NEXT_PUBLIC_PAYROLL_SERVICE_URL=http://localhost:8084
NEXT_PUBLIC_ATTENDANCE_SERVICE_URL=http://localhost:8085
NEXT_PUBLIC_CONNECT_SERVICE_URL=http://localhost:8086
NEXT_PUBLIC_AI_GATEWAY_URL=http://localhost:8087
NEXT_PUBLIC_RULE_ENGINE_URL=http://localhost:8088
NEXT_PUBLIC_SOCIAL_MEDIA_SERVICE_URL=http://localhost:8089
