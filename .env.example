# ========================================
# LERA Group v192 - Environment Variables
# ========================================

# =========================================
# DATABASE CONFIGURATION
# =========================================
DB_HOST=postgres
DB_PORT=5432
DB_NAME=lera
DB_USER=lera
# REQUIRED — no fallback in source. Set a strong password per environment.
DB_PASSWORD=change-me

# =========================================
# JWT AUTHENTICATION
# =========================================
# REQUIRED — no fallback in source; services fail to start if unset.
# Base64-decoded for HS256, so use a valid Base64 string >= 32 bytes,
# e.g. generate with: openssl rand -base64 48
JWT_SECRET=change-me-base64-secret
JWT_EXPIRATION=86400000
# JWT_EXPIRATION in milliseconds (86400000 = 24 hours)

# =========================================
# AI INTEGRATION (OpenAI)
# =========================================
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=2000

# =========================================
# EMAIL CONFIGURATION (SMTP)
# Use the standard Spring Boot names — they auto-bind to spring.mail.* and create the
# JavaMailSender ONLY when SPRING_MAIL_HOST is set (services skip email gracefully if unset).
# Setting these enables password-reset + notification emails across identity/connect/
# payment/attendance with no code change.
# =========================================
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=your-email@gmail.com
SPRING_MAIL_PASSWORD=your-app-password-here
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true
# From header used by transactional mail (LERA mail service):
LERA_MAIL_FROM=noreply@leragroup.com

# =========================================
# CRM MESSAGING (Zalo / SMS)
# Outbound messages record SKIPPED until these are set; then they send for real.
# Zalo ZNS (phone-based, requires an approved template in the Zalo OA console):
# MESSAGING_ZALO_ACCESS_TOKEN=your-zalo-oa-access-token
# MESSAGING_ZALO_TEMPLATE_ID=your-approved-zns-template-id
# MESSAGING_ZALO_ENDPOINT=https://business.openapi.zalo.me/message/template
# Generic SMS provider (eSMS, Twilio, …) — POST {to, from, message}:
# MESSAGING_SMS_API_KEY=your-sms-provider-key
# MESSAGING_SMS_ENDPOINT=https://provider.example/api/send
# MESSAGING_SMS_SENDER=LERA

# =========================================
# SPRING BOOT CONFIGURATION
# =========================================
SPRING_PROFILES_ACTIVE=docker

# =========================================
# FRONTEND CONFIGURATION
# =========================================
NEXT_PUBLIC_API_BASE=http://localhost/api
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# =========================================
# FILE STORAGE (academy_service — local or S3/MinIO)
# =========================================
# LERA_STORAGE_BACKEND=local
# LERA_UPLOAD_DIR=/var/lera/uploads/
# LERA_ATTACHMENTS_DIR=/var/lera/uploads/
# Docker MinIO (docker-compose) — REQUIRED when running the minio service (no defaults in compose):
MINIO_ROOT_USER=change-me
MINIO_ROOT_PASSWORD=change-me
# LERA_STORAGE_BACKEND=s3
# AWS_S3_BUCKET=lera-files
# AWS_REGION=ap-southeast-1
# AWS_S3_ENDPOINT=http://localhost:9000
# AWS_S3_PATH_STYLE=true
# LERA_STORAGE_PUBLIC_BASE_URL=http://localhost:9000/lera-files
# AWS_ACCESS_KEY_ID=change-me
# AWS_SECRET_ACCESS_KEY=change-me

# =========================================
# PAYMENT GATEWAY (Optional)
# =========================================
# STRIPE_API_KEY=sk_test_your_stripe_key
# RAZORPAY_KEY_ID=your_razorpay_key
# RAZORPAY_KEY_SECRET=your_razorpay_secret

# =========================================
# REDIS (Optional - for caching)
# =========================================
# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_PASSWORD=

# =========================================
# NATIVE PUSH (connect_service — APNs / FCM / Web Push)
# =========================================
# LERA_PUSH_ENABLED=true
# APNS_TEAM_ID=
# APNS_KEY_ID=
# APNS_BUNDLE_ID=com.lera.app
# APNS_KEY_PATH=/path/to/AuthKey_XXX.p8
# APNS_SANDBOX=true
# FCM_PROJECT_ID=
# FCM_SERVICE_ACCOUNT_PATH=/path/to/lera-mobile-fcm.json
# Web Push (browser): VAPID keys — see connect_service application.properties

# =========================================
# PLACEMENT SYNC & INTERNAL TRIGGERS (notifications, CRM → academy)
# =========================================
# Shared secret for X-Internal-Key between connect_service, academy_service, identity_service.
# Set the same value in every service that receives internal calls (local dev: see .env.development).
LERA_INTERNAL_API_KEY=change-me
# Base URL of academy_service (e.g. placement-record after lead convert). No trailing slash.
LERA_ACADEMY_URL=http://localhost:8082
# Academy → attendance_service sync when a class session is marked COMPLETED (teacher_sessions + payroll attendance).
ATTENDANCE_SERVICE_URL=http://localhost:8085

# =========================================
# FRONTEND REWRITES (local dev) — see frontend/next.config.js
# =========================================
# Default stack: ./start-lera.sh (core only). For AI and rules features, either:
#   ./start-lera.sh --include-ai
# or start services manually and point the frontend here (optional overrides):
# AI_GATEWAY_URL=http://localhost:8087
# RULE_ENGINE_URL=http://localhost:8088
# Social rewrites use social_media_service on 8089 — use ./start-lera.sh --include-social

# =========================================
# APPLICATION SETTINGS
# =========================================
APP_NAME=LERA Group
APP_VERSION=v192-final
APP_ENV=development

# =========================================
# LOGGING
# =========================================
LOG_LEVEL=INFO
# Options: TRACE, DEBUG, INFO, WARN, ERROR

# =========================================
# PGADMIN CONFIGURATION
# =========================================
PGADMIN_EMAIL=admin@lera.com
# REQUIRED when running the pgadmin service (no default in compose).
PGADMIN_PASSWORD=change-me

# =========================================
# NOTES:
# =========================================
# 1. Copy this file to .env for local development
# 2. Never commit .env to version control
# 3. Update sensitive values in production
# 4. Use GitHub Secrets for CI/CD deployment
